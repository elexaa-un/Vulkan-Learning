#version 450

// ============================================================
// 全屏后处理 - 顶点着色器
// ============================================================
// 作用：生成一个覆盖整个屏幕的大三角形。
//       不需要任何顶点缓冲区或 VBO。
//       利用 gl_VertexIndex 直接生成三个顶点。
//
// 原理：
//   裁剪空间范围是 [-1, -1] 到 [1, 1]
//   这三个顶点的位置是：
//     (-1, -1) 左下角
//     ( 3, -1) 右下角（超出右边界，但会被裁剪到屏幕边缘）
//     (-1,  3) 左上角（超出上边界，但会被裁剪到屏幕边缘）
//   结果：恰好覆盖整个屏幕的一个大三角形
// ============================================================

layout(location = 0) out vec2 fragTexCoord;

void main()
{
    // 只用 3 个顶点覆盖全屏（不需要顶点缓冲区/VBO）
    vec2 positions[3] = vec2[](
        vec2(-1.0, -1.0),  // 顶点 0：屏幕左下角
        vec2( 3.0, -1.0),  // 顶点 1：屏幕右下角（远在右侧之外）
        vec2(-1.0,  3.0)   // 顶点 2：屏幕左上角（远在上方之外）
    );

    vec2 uvs[3] = vec2[](
        vec2(0.0, 0.0),    // 顶点 0：纹理左下角
        vec2(2.0, 0.0),    // 顶点 1：纹理右下角（超出的部分会被截断）
        vec2(0.0, 2.0)     // 顶点 2：纹理左上角
    );

    gl_Position = vec4(positions[gl_VertexIndex], 0.0, 1.0);
    fragTexCoord = uvs[gl_VertexIndex];
}
