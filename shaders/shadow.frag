#version 450

// ============================================================
// Shadow Map 片段着色器（最小化版本）
// ============================================================
// 作用：虽然 Shadow Pass 不需要输出颜色，但 Vulkan 的图形管线
//       仍然要求绑定片段着色器。这里输出一个空的 vec4。
//       实际深度由 GPU 自动写入深度附件。
// ============================================================

layout(location = 0) out vec4 outColor;

void main() {
    // 不需要任何操作，深度由硬件自动写入
    // 这里只是为了让管线创建成功
    outColor = vec4(0.0);
}
