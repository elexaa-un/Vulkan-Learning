# Build 目录（CMake 编译输出）
build/
cmake-build-*/
out/

# IDE 配置文件（可选忽略，防止不同开发者提交个性化设置）
.vscode/
.idea/
*.swp
*.swo
*~

# CMake 生成文件
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# 编译输出文件（可执行文件、库、对象文件）
*.exe
*.exe.*
*.dll
*.so
*.dylib
*.a
*.lib
*.o
*.obj

# Vulkan 相关（SDK 中间文件）
*.spv
shaders/*.spv

# 操作系统生成文件
.DS_Store
Thumbs.db

# 日志和性能文件
*.log
*.profraw
*.gcda
*.gcno